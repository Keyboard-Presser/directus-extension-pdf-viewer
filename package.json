{
  "name": "directus-extension-pdf-viewer",
  "version": "1.0.0",
  "description": "Upload a PDF and preview it inline in the Directus item view",
  "keywords": [
    "directus",
    "directus-extension",
    "directus-custom-interface",
    "pdf",
    "pdf-viewer",
    "file-upload"
  ],
  "author": {
    "name": "Prince Panfoh",
    "url": "https://github.com/Keyboard-Presser"
  },
  "license": "MIT",
  "homepage": "https://github.com/Keyboard-Presser/directus-extension-pdf-viewer#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Keyboard-Presser/directus-extension-pdf-viewer.git"
  },
  "bugs": {
    "url": "https://github.com/Keyboard-Presser/directus-extension-pdf-viewer/issues"
  },
  "icon": "picture_as_pdf",
  "type": "module",
  "files": ["dist"],
  "directus:extension": {
    "type": "interface",
    "path": "dist/index.js",
    "source": "src/index.js",
    "host": "^10.10.0"
  },
  "scripts": {
    "build": "directus-extension build",
    "dev": "directus-extension build --watch"
  },
  "devDependencies": {
    "@directus/extensions-sdk": "^17.0.11",
    "vue": "^3.5.24"
  }
}
